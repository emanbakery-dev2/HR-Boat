# generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=****

# required for non-vercel deployments, vercel uses OIDC automatically
# https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=****

# https://vercel.com/docs/vercel-blob
BLOB_READ_WRITE_TOKEN=****

# https://vercel.com/docs/postgres
POSTGRES_URL=****

# https://vercel.com/docs/redis
REDIS_URL=****

# ── Muqeem API (Saudi MOI resident management platform) ──────────────────────
# Get these from the Muqeem developer/integration portal
MUQEEM_BASE_URL=https://muqeem.sa
MUQEEM_APP_ID=****
MUQEEM_APP_KEY=****
# Muqeem platform login credentials (the username & password you use on muqeem.sa)
MUQEEM_USERNAME=****
MUQEEM_PASSWORD=****
